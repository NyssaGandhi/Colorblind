{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "1a2a0d795b7741e49b2f6f4824bfc49e",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ColorblindMath (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -331.0,
            "y": 208.0,
            "width": 242.00003051757813,
            "height": 118.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "ca66adafc16848aca2741e1ed40854f4"
        },
        {
            "m_Id": "f97076d81be64ecea7ff3ca8e55811ce"
        },
        {
            "m_Id": "c5fad20d536d427ea31a2eb7f6d4c7e0"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ColorblindMath",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float3 outRGB = Color;\r\n\r\n// Protanopia (Red-Blind)\r\nif (Mode == 1) {\r\n    outRGB.r = (Color.r * 0.56667) + (Color.g * 0.43333);\r\n    outRGB.g = (Color.r * 0.55833) + (Color.g * 0.44167);\r\n    outRGB.b = (Color.g * 0.24167) + (Color.b * 0.75833);\r\n}\r\n// Deuteranopia (Green-Blind)\r\nelse if (Mode == 2) {\r\n    outRGB.r = (Color.r * 0.625) + (Color.g * 0.375);\r\n    outRGB.g = (Color.r * 0.7) + (Color.g * 0.3);\r\n    outRGB.b = (Color.g * 0.3) + (Color.b * 0.7);\r\n}\r\n// Tritanopia (Blue-Blind)\r\nelse if (Mode == 3) {\r\n    outRGB.r = (Color.r * 0.95) + (Color.g * 0.05);\r\n    outRGB.g = (Color.g * 0.43333) + (Color.b * 0.56667);\r\n    outRGB.b = (Color.g * 0.475) + (Color.b * 0.525);\r\n}\r\n\r\nOutColor = outRGB;"
}

